{
  "name": "svelte-devtools-pro",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter playground dev",
    "check": "pnpm -r check",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependenciesWrittenByPnpm": true
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}